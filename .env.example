# The app runs with NO config on sample data, no login. The variables below
# unlock live data and secure in-app credential storage when you're ready.

# ─── Secure mode (login + in-app credential storage) ────────────────
# Setting DASHBOARD_USERS turns ON login. Without it, the app stays open.
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=               # e.g. https://cfmfhe-analytics.vercel.app
DASHBOARD_USERS=            # "David Love|david@x.com|pass,Luke Alley|luke@x.com|pass"
APP_ENCRYPTION_KEY=         # random string; encrypts saved credentials at rest

# Vercel KV / Upstash Redis — so saved credentials persist across restarts
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Data sources ───────────────────────────────────────────────────
# Optional: set here OR enter them in-app on the Connections page (secure mode).
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_WOOCOMMERCE_SHEET_ID=
GOOGLE_SHEETS_SHOPIFY_SHEET_ID=

KLAVIYO_API_KEY=
KLAVIYO_ACCOUNT_ID=Vs3idx

GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

ANTHROPIC_API_KEY=

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
