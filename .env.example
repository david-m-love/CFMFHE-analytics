# Nothing here is required to run or deploy — the app works out of the box on
# a built-in sample dataset (no login). Add these later to wire live data.

# ─── Google Sheets (order data) ─────────────────────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_WOOCOMMERCE_SHEET_ID=
GOOGLE_SHEETS_SHOPIFY_SHEET_ID=

# ─── Klaviyo (email/SMS) ────────────────────────────────────────────
KLAVIYO_API_KEY=
KLAVIYO_ACCOUNT_ID=Vs3idx

# ─── Google Analytics 4 (traffic) ──────────────────────────────────
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# ─── Anthropic (Ask Anything) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
