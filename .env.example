# ─── Auth (NextAuth) ────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Dashboard users — format: "Name|email|password,Name2|email2|password2"
# If unset, a demo user (admin@cfmfhe.com / cfmfhe-demo) is seeded in dev only.
DASHBOARD_USERS=

# ─── Google Sheets (order data) ─────────────────────────────────────
# Leave blank to run on sample/mock data until the sync is live.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_WOOCOMMERCE_SHEET_ID=
GOOGLE_SHEETS_SHOPIFY_SHEET_ID=

# ─── Klaviyo (email/SMS) ────────────────────────────────────────────
KLAVIYO_API_KEY=
KLAVIYO_ACCOUNT_ID=Vs3idx

# ─── Google Analytics 4 (traffic) ──────────────────────────────────
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# ─── Anthropic (Ask Anything) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
